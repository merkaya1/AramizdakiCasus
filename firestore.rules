rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /rooms/{roomId} {

      // Sadece giriş yapmış kullanıcılar okuyabilir
      allow read: if isAuthenticated();

      // Oda oluşturma: hostId kendisi olmalı, status lobby olmalı
      allow create: if isAuthenticated()
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.status == 'lobby'
        && request.resource.data.players.size() == 1;

      // Oda güncelleme: Giriş yapmış kullanıcı
      // NOT: Cloud Functions olmadan oyuncu bazlı kısıtlama yapılamıyor
      // (players array of objects, rules'da iterate edilemiyor)
      allow update: if isAuthenticated();

      // Oda silme: Son oyuncu ayrılırken
      allow delete: if isAuthenticated();
    }

    // Diğer tüm collection'ları kapat
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
      return request.auth != null;
    }
  }
}
